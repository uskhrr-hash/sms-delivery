# --- Сервис ---
APP_NAME=SMS Delivery
DEBUG=false
DATABASE_URL=postgresql+psycopg://sms:sms@db:5432/sms_delivery
# Для локальной разработки без Docker:
# DATABASE_URL=sqlite:///./data/sms_delivery.db

# API-ключи сайтов: имя:ключ,имя:ключ
API_KEYS=booking:change-me-booking,shop:change-me-shop

# Админка (простая веб-панель)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Пауза между исходящими СМС (имитация «набора руками»), секунды
SEND_DELAY_MIN=60
SEND_DELAY_MAX=180

# --- SMS Gateway (Private Server на том же VPS) ---
# Базовый URL без /api/... — добавится в клиенте
SMSGATE_BASE_URL=https://sms.example.com
# Логин/пароль ниже — запасной вариант (диагностика, webhook).
# Для отправки СМС у каждого телефона свои учётные данные в админке /admin/
SMSGATE_USERNAME=
SMSGATE_PASSWORD=

# URL этого сервиса (для регистрации webhook входящих СМС)
PUBLIC_BASE_URL=https://sms-delivery.example.com
